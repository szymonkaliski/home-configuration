#!/usr/bin/env bash

# kMDItemTextContent would be a better fit, but doesn't seem to work everywhere (for example in Alfred)
#
# reference: https://gist.github.com/pnc/b7fb38d70f157cd40595d9e52bebc055

set -e

if [ -z "$*" ]; then
  echo "pass image file as argument"
  exit 1
fi

FORCE=0
URL=""

while (( "$#" )); do
  case "$1" in
    --force)
      FORCE=1
      shift 1
      ;;
    --url)
      URL="$2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

echo "adding OCR data to: $1"

if [[ $FORCE -eq 0 ]] && xattr "$1" | grep -q "kMDItemFinderComment"; then
  echo "file $1 alredy has kMDItemFinderComment, exiting"
  exit 0
fi

TINYOCR="$HOME/.bin/tinyocr"
XML="$HOME/.nix-profile/bin/xml"

# Dropbox has a ~4KB xattr size limit; files exceeding it fail to sync. Binary
# plist overhead is ~46 bytes, and strings are stored as UTF-16 (2 bytes/char),
# so 1850 chars ~= 3746 bytes which is safely under the limit.
MAX_CHARS=1850

RAW=$("$TINYOCR" "$1")
if [ -n "$URL" ]; then
  RAW="$URL

$RAW"
fi
if [ ${#RAW} -gt $MAX_CHARS ]; then
  RAW="${RAW:0:$MAX_CHARS}..."
fi

CONTENTS=$($XML esc <<< "$RAW")

HEX=$((cat << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<string>$CONTENTS</string>
</plist>
EOF
) | plutil -convert binary1 - -o - | xxd -p | tr -d '\n')

# Finder comments live in TWO places: the xattr and .DS_Store. Spotlight's
# mdworker treats .DS_Store as authoritative — if the comment isn't there,
# mdworker clears the xattr on reindex. Register in .DS_Store first via Finder,
# then overwrite the xattr with our controlled binary plist (for Dropbox compat).
osascript \
  -e 'on run argv' \
  -e 'tell application "Finder" to set comment of (POSIX file (item 1 of argv) as alias) to (item 2 of argv)' \
  -e 'end run' -- "$1" "$RAW" \
  || echo "warning: osascript failed to set Finder comment in .DS_Store"

xattr -w -x com.apple.metadata:kMDItemFinderComment "$HEX" "$1"

mdimport "$1"

# Verify the xattr survived mdimport and any async Spotlight/Dropbox processing.
for attempt in 1 2 3 4 5; do
  sleep 2
  if xattr "$1" | grep -q kMDItemFinderComment; then
    break
  fi
  echo "xattr stripped after mdimport (attempt $attempt), re-writing..."
  xattr -w -x com.apple.metadata:kMDItemFinderComment "$HEX" "$1"
done
