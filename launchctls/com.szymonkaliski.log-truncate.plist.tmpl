<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC -//Apple Computer//DTD PLIST 1.0//EN http://www.apple.com/DTDs/PropertyList-1.0.dtd>
<plist version="1.0">
    <dict>
        <key>Label</key>
        <string>com.szymonkaliski.log-truncate</string>
        <key>ProgramArguments</key>
        <array>
            <string>/bin/bash</string>
            <string>LAUNCHCTL_SCRIPTS_PATH/log-truncate.sh</string>
        </array>
        <key>StartCalendarInterval</key>
        <dict>
            <key>Hour</key>
            <integer>4</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </dict>
</plist>
