{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebFetch",
      "WebSearch",
      "Bash(tmux *)",
      "Bash(echo $TMUX_PANE)",
      "Bash(cat *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(hostname *)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(uname *)",
      "Bash(which *)",
      "mcp__chrome-devtools__*",
      "mcp__playwright__*"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/pre-read-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "playground@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Thinking",
      "Working",
      "Processing",
      "Analyzing",
      "Reading",
      "Writing",
      "Searching"
    ]
  },
  "effortLevel": "xhigh",
  "promptSuggestionEnabled": false,
  "skipAutoPermissionPrompt": true
}
