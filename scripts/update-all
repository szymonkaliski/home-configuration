#!/usr/bin/env bash

function gitUpdate {
  if [ -d "$*" ]; then
    pushd "$*" > /dev/null || return

    if [ -e .git ]; then
      echo -e "$(tput setaf 2)Checking $(basename "$*")...$(tput sgr0)"
      git pull
      echo
    fi

    popd > /dev/null || return
  fi
}

HOSTNAME=$(hostname -s)
NVD_LOG="$HOME/.local/state/update-all.log"

mkdir -p "$(dirname "$NVD_LOG")"

nvd_diff() {
  local label="$1" before="$2" after="$3"
  local output

  if [ -z "$before" ] || [ -z "$after" ]; then
    output="(skipped: missing before/after path)"
  elif [ "$before" = "$after" ]; then
    output="No changes."
  else
    output=$(nix run nixpkgs#nvd -- diff "$before" "$after" 2>&1)
  fi

  echo
  echo -e "$(tput setaf 2)Diffing $label...$(tput sgr0)"
  echo "$output"

  {
    echo "[$(date -Iseconds 2>/dev/null || date)] $label"
    echo "$output"
    echo
  } >> "$NVD_LOG"
}

# pull the home-configuration repo first (resolve symlink to find repo root)
REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
gitUpdate "$(dirname "$(dirname "$REAL_SCRIPT")")"

if [[ $HOSTNAME == "orchid" ]]; then
  echo -e "$(tput setaf 2)Checking Nix...$(tput sgr0)"

  pushd ~/.config/home-manager > /dev/null || exit 1

  HM_BEFORE=$(readlink -f ~/.local/state/nix/profiles/home-manager 2>/dev/null)

  sudo determinate-nixd upgrade
  nix flake update
  home-manager switch --flake .#szymon@orchid

  HM_AFTER=$(readlink -f ~/.local/state/nix/profiles/home-manager 2>/dev/null)
  nvd_diff "home-manager" "$HM_BEFORE" "$HM_AFTER"
  echo

  popd > /dev/null || exit 1
elif [[ $HOSTNAME == "minix" ]]; then
  echo -e "$(tput setaf 2)Checking Nix...$(tput sgr0)"

  pushd ~/.config/home-manager > /dev/null || exit 1

  SYSTEM_BEFORE=$(readlink -f /run/current-system 2>/dev/null)
  HM_BEFORE=$(readlink -f ~/.local/state/nix/profiles/home-manager 2>/dev/null)

  nix flake update
  sudo nixos-rebuild switch --flake .#minix
  home-manager switch --flake .#szymon@minix

  SYSTEM_AFTER=$(readlink -f /nix/var/nix/profiles/system 2>/dev/null)
  HM_AFTER=$(readlink -f ~/.local/state/nix/profiles/home-manager 2>/dev/null)
  nvd_diff "system" "$SYSTEM_BEFORE" "$SYSTEM_AFTER"
  nvd_diff "home-manager" "$HM_BEFORE" "$HM_AFTER"
  echo

  popd > /dev/null || exit 1
fi

if [ -d ~/.zsh/plugins ]; then
  for i in ~/.zsh/plugins/*; do
    gitUpdate "$i"
  done
fi

if [ -d ~/.tmux/plugins ]; then
  for i in ~/.tmux/plugins/*; do
    gitUpdate "$i"
  done
fi

if command -v npm > /dev/null 2>&1; then
  echo -e "$(tput setaf 2)Checking NPM...$(tput sgr0)"
  npm-sync
  echo
fi

if hash vale 2> /dev/null; then
  pushd ~/ > /dev/null || exit 1
  echo -e "$(tput setaf 2)Checking Vale...$(tput sgr0)"
  vale sync
  popd > /dev/null || exit 1
fi
