#!/usr/bin/env bash

# OPTIONS is intentionally word-split below, but must never be glob-expanded
# (the gif filtergraph contains [s0]/[s1] which are glob bracket patterns).
set -f

# set ffmpeg options
case $1 in
  ipad|iPad)
    OPTIONS="-c:a aac -ac 2 -b:a 160k -s 1024x768 -c:v libx264 -preset slow -crf 23 -movflags +faststart"
    EXT=".iPad.mp4"
    ;;
  mjpeg)
    OPTIONS="-c:v mjpeg -qscale 1 -an"
    EXT=".MJPEG.avi"
    ;;
  h264)
    OPTIONS="-c:v libx264 -preset slow -crf 20 -pix_fmt yuv420p -c:a aac -b:a 128k -movflags +faststart -max_muxing_queue_size 1024"
    EXT=".H264.mp4"
    ;;
  h265|hevc)
    OPTIONS="-c:v libx265 -preset medium -crf 26 -tag:v hvc1 -pix_fmt yuv420p -c:a aac -b:a 128k -movflags +faststart -max_muxing_queue_size 1024"
    EXT=".H265.mp4"
    ;;
  av1)
    OPTIONS="-c:v libsvtav1 -preset 6 -crf 32 -pix_fmt yuv420p -c:a aac -b:a 128k -movflags +faststart -max_muxing_queue_size 1024"
    EXT=".AV1.mp4"
    ;;
  gif)
    OPTIONS="-vf fps=12,scale=640:-1:flags=lanczos,split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse -loop 0"
    EXT=".gif"
    ;;
  mp3)
    OPTIONS="-c:a libmp3lame -b:a 320k -ar 44100"
    EXT=".mp3"
    ;;
  wav)
    OPTIONS="-ar 44100"
    EXT=".wav"
    ;;
  remove-audio)
    OPTIONS="-c:v copy -an"
    EXT=".no-audio.mp4"
    ;;
  *)
    echo "Usage: $0 [ipad|mjpeg|h264|h265|av1|gif|mp3|wav|remove-audio] [files]"
    exit 0
    ;;
esac

# remove first attribute given from command line
shift

# convert files
for f in "$@"
do
  if [[ -n $EXT ]]; then
    ffmpeg -threads 0 -i "${f}" $OPTIONS "${f%.*}$EXT"
  else
    ffmpeg -threads 0 -i "${f}" $OPTIONS
  fi
done
