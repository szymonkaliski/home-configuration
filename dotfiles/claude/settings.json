{
  "env": {
    "DISABLE_INSTALLATION_CHECKS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebFetch",
      "WebSearch",
      "Bash(tmux *)",
      "Bash(echo $TMUX_PANE)",
      "Bash(cat *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(hostname *)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(uname *)",
      "Bash(which *)",
      "Bash(trash:*)",
      "mcp__chrome-devtools__*",
      "mcp__playwright__*"
    ],
    "defaultMode": "auto"
  },
  "model": "fable",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.js"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.js"
          }
        ]
      }
    ]
  },
  "workflowKeywordTriggerEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Thinking",
      "Working",
      "Processing",
      "Analyzing",
      "Reading",
      "Writing",
      "Searching"
    ]
  },
  "effortLevel": "xhigh",
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "verbose": false,
  "preferredNotifChannel": "notifications_disabled",
  "fileCheckpointingEnabled": false,
  "terminalProgressBarEnabled": false,
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true
}
