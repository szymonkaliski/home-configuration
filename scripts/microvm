#!/usr/bin/env bash
set -euo pipefail

VM_BASE="$HOME/MicroVMs"
HOST_DIR="$VM_BASE/host"
SSH_OPTS=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR)
MAX_VMS=4

# mirror of sizing in dotfiles/nix/hosts/minix/microvms/default.nix
vm_size() {
  case "$1" in
    1|2) echo "lg" ;;
    *)   echo "sm" ;;
  esac
}

REPO_SETUP_SH="$HOME/Projects/home-configuration/dotfiles/nix/hosts/minix/microvms/setup.sh"


sync_host_config() {
  mkdir -p "$HOST_DIR"
  rm -rf "$HOST_DIR/claude" "$HOST_DIR/ssh" "$HOST_DIR/claude.json" "$HOST_DIR/gemini"

  command cp -rL "$HOME/.claude" "$HOST_DIR/claude" 2>/dev/null || true
  command cp -L "$HOME/.claude.json" "$HOST_DIR/claude.json" 2>/dev/null || true
  command cp -rL "$HOME/.ssh" "$HOST_DIR/ssh" 2>/dev/null || true
  command cp -rL "$HOME/.gemini" "$HOST_DIR/gemini" 2>/dev/null || true

  {
    echo "#!/usr/bin/env bash"
    echo "# DO NOT EDIT - copied from dotfiles/nix/hosts/minix/microvms/setup.sh"
    tail -n +2 "$REPO_SETUP_SH"
  } > "$HOST_DIR/setup.sh"

  chmod +x "$HOST_DIR/setup.sh"
}

find_free_vm() {
  local want_size="${1:-}"
  for i in $(seq 1 "$MAX_VMS"); do
    [ -n "$want_size" ] && [ "$(vm_size "$i")" != "$want_size" ] && continue
    local state
    state=$(systemctl is-active "microvm@vm-${i}" 2>/dev/null || true)
    if [ "$state" = "inactive" ] || [ "$state" = "failed" ]; then
      echo "$i"
      return
    fi
  done
  if [ -n "$want_size" ]; then
    echo "error: no free ${want_size} VMs" >&2
  else
    echo "error: all VMs in use" >&2
  fi
  exit 1
}

cmd_start() {
  local VM="" PROJECT="." SIZE=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --dir) PROJECT="$2"; shift 2 ;;
      --size) SIZE="$2"; shift 2 ;;
      lg|sm) SIZE="$1"; shift ;;
      *) VM="$1"; shift ;;
    esac
  done
  [ -z "$VM" ] && VM=$(find_free_vm "$SIZE")
  PROJECT=$(realpath "$PROJECT")
  mkdir -p "$VM_BASE/vm-${VM}/data/home"
  rm -rf "$VM_BASE/vm-${VM}/workspace"
  ln -s "$PROJECT" "$VM_BASE/vm-${VM}/workspace"
  sync_host_config
  t0=$SECONDS
  printf "vm-${VM} (10.100.0.${VM}) ${PROJECT}\n"
  printf "starting..."
  sudo systemctl reset-failed "microvm@vm-${VM}" 2>/dev/null || true
  sudo systemctl start --no-block "microvm@vm-${VM}"
  printf " booting..."
  while true; do
    local setup_state
    setup_state=$(ssh -o ConnectTimeout=1 "${SSH_OPTS[@]}" "szymon@10.100.0.${VM}" \
      'systemctl is-active setup-user.service' 2>/dev/null || true)
    if [ "$setup_state" = "active" ]; then
      break
    fi
    if [ "$setup_state" = "failed" ]; then
      echo " failed"
      echo "error: setup-user.service failed in vm-${VM}" >&2
      exit 1
    fi
    local svc_state
    svc_state=$(systemctl is-active "microvm@vm-${VM}" 2>/dev/null || true)
    if [ "$svc_state" = "failed" ]; then
      echo " failed"
      echo "error: microvm@vm-${VM} failed to start" >&2
      exit 1
    fi
    sleep 0.5
  done
  elapsed=$(( SECONDS - t0 ))
  failed=$(ssh "${SSH_OPTS[@]}" "szymon@10.100.0.${VM}" "systemctl --failed --no-legend --no-pager" 2>/dev/null || true)
  if [ -n "$failed" ]; then
    echo " ready (${elapsed}s, with failures)"
    echo "$failed"
  else
    echo " ready (${elapsed}s)"
  fi
  notify-pushover "vm-${VM} ready (${elapsed}s) ${PROJECT##*/}" 2>/dev/null || true
  exec ssh -t "${SSH_OPTS[@]}" "szymon@10.100.0.${VM}"
}

stop_vm() {
  local VM="$1"
  ssh -o ConnectTimeout=3 "${SSH_OPTS[@]}" "szymon@10.100.0.${VM}" "sudo tailscale logout" 2>/dev/null || true
  sudo systemctl stop "microvm@vm-${VM}"
}

cmd_stop() {
  [ $# -lt 1 ] && echo "usage: microvm stop <N>" && exit 1
  echo "stopping vm-${1}..."
  stop_vm "$1"
  echo "vm-${1} stopped"
}

cmd_ssh() {
  [ $# -lt 1 ] && echo "usage: microvm ssh <N>" && exit 1
  if ! systemctl is-active "microvm@vm-${1}" &>/dev/null; then
    echo "error: vm-${1} is not running" >&2; exit 1
  fi
  ssh -t "${SSH_OPTS[@]}" "szymon@10.100.0.${1}"
}

cmd_list() {
  for i in $(seq 1 "$MAX_VMS"); do
    state=$(systemctl is-active "microvm@vm-${i}" 2>/dev/null || true)
    case "$state" in
      active|activating) status="running" ;;
      deactivating) status="stopping" ;;
      *) status="stopped" ;;
    esac
    ws=$(readlink "$VM_BASE/vm-${i}/workspace" 2>/dev/null || echo "(none)")
    printf "vm-%-2d %-2s  %-8s  %s\n" "$i" "$(vm_size "$i")" "$status" "$ws"
  done
}

cmd_stop_all() {
  local pids=()
  for i in $(seq 1 "$MAX_VMS"); do
    if systemctl is-active "microvm@vm-${i}" &>/dev/null; then
      echo "stopping vm-${i}..."
      stop_vm "$i" &
      pids+=($!)
    fi
  done
  wait "${pids[@]}" 2>/dev/null
  echo "all stopped"
}

kill_vm() {
  local VM="$1"
  sudo systemctl kill "microvm@vm-${VM}"
  sudo systemctl stop "microvm@vm-${VM}" 2>/dev/null || true
}

cmd_kill() {
  [ $# -lt 1 ] && echo "usage: microvm kill <N>" && exit 1
  kill_vm "$1"
  echo "killed vm-${1}"
}

cmd_kill_all() {
  local pids=()
  for i in $(seq 1 "$MAX_VMS"); do
    if systemctl is-active "microvm@vm-${i}" &>/dev/null; then
      echo "killing vm-${i}..."
      kill_vm "$i" &
      pids+=($!)
    fi
  done
  wait "${pids[@]}" 2>/dev/null
  echo "all killed"
}

clean_vm() {
  local VM="$1"
  sudo rm -f "/var/lib/microvms/vm-${VM}/nix-store-overlay.img"
  sudo rm -rf "$VM_BASE/vm-${VM}/data"
  rm -f "$VM_BASE/vm-${VM}/workspace"
}

cmd_clean() {
  [ $# -lt 1 ] && echo "usage: microvm clean <N>" && exit 1
  if systemctl is-active "microvm@vm-${1}" &>/dev/null; then
    echo "error: vm-${1} is running, stop it first" >&2; exit 1
  fi
  clean_vm "$1"
  echo "vm-${1} cleaned"
}

cmd_clean_all() {
  local pids=()
  for i in $(seq 1 "$MAX_VMS"); do
    if systemctl is-active "microvm@vm-${i}" &>/dev/null; then
      echo "skipping vm-${i} (running)"
      continue
    fi
    clean_vm "$i" &
    pids+=($!)
  done
  wait "${pids[@]}" 2>/dev/null
  echo "all cleaned"
}

cmd_restart() {
  [ $# -lt 1 ] && echo "usage: microvm restart <N>" && exit 1
  local VM="$1"
  if ! systemctl is-active "microvm@vm-${VM}" &>/dev/null; then
    echo "error: vm-${VM} is not running" >&2; exit 1
  fi
  local ws
  ws=$(readlink "$VM_BASE/vm-${VM}/workspace" 2>/dev/null || true)
  [ -z "$ws" ] && echo "error: no workspace for vm-${VM}" >&2 && exit 1
  echo "stopping vm-${VM}..."
  stop_vm "$VM"
  echo "restarting..."
  cmd_start "$VM" --dir "$ws"
}

cmd_usage() {
  cat <<EOF
usage: microvm <command> [args]

  list, ls                 show all VMs

  start   [N|lg|sm] [--dir path]
                           start VM (default: current dir, auto-picks VM;
                           lg/sm filters the auto-pick by size)
  ssh     N                ssh into running VM
  stop    N                stop VM
  restart N                restart VM (preserves workspace)
  kill    N                kill VM
  clean   N                clean all ephemeral data for VM

  stop-all                 stop all VMs
  kill-all                 kill all VMs
  clean-all                clean all stopped VMs
EOF
}

CMD="${1:-help}"
shift || true

case "$CMD" in
  start)     cmd_start "$@" ;;
  stop)      cmd_stop "$@" ;;
  ssh)       cmd_ssh "$@" ;;
  list|ls)   cmd_list ;;
  stop-all)  cmd_stop_all ;;
  kill)      cmd_kill "$@" ;;
  kill-all)  cmd_kill_all ;;
  clean)     cmd_clean "$@" ;;
  clean-all) cmd_clean_all ;;
  restart)   cmd_restart "$@" ;;
  *)         cmd_usage ;;
esac
